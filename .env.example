# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://triaje:triaje_pass@db:5432/hospitaltriaje

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Firebase / FCM ────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=./firebase-credentials.json

# ── Maps ──────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Postgres (used by docker-compose) ─────────────────────────────────────────
POSTGRES_USER=triaje
POSTGRES_PASSWORD=triaje_pass
POSTGRES_DB=hospitaltriaje

# ── PgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@hospitaltriaje.local
PGADMIN_DEFAULT_PASSWORD=admin

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://localhost:8000,http://localhost:3000,http://10.0.2.2:8000

# ── SSE ───────────────────────────────────────────────────────────────────────
SSE_MAX_CONNECTIONS_PER_IP=10
